graph TB
    Customer["👤 Customer Request<br/>(Text Input)"]
    Response["✉️ Customer Response<br/>(Text Output)"]

    Orch["🎯 Orchestrator Agent<br/>Responsibility: route requests, evaluate intent quality, delegate to workers, and return final response"]

    subgraph Workers["Worker Agents (Distinct Responsibilities)"]
        Inv["📦 Inventory Agent<br/>Responsibility: check stock levels and assess reorder needs"]
        Quote["💰 Quoting Agent<br/>Responsibility: generate customer quotes using history and discount logic"]
        Sales["🛒 Sales Agent<br/>Responsibility: finalize orders and record transactions"]
    end

    subgraph Tools["Agent Tools (Helper Function + Purpose)"]
        T1["get_stock_level()<br/>Purpose: check stock for a specific item on a request date"]
        T2["get_all_inventory()<br/>Purpose: retrieve full inventory snapshot for quote and order context"]
        T3["get_supplier_delivery_date()<br/>Purpose: estimate delivery date for reorder shortages"]
        T4["search_quote_history()<br/>Purpose: find relevant historical quotes for pricing decisions"]
        T5["create_transaction()<br/>Purpose: persist sales or stock-order transactions"]
        T6["get_cash_balance()<br/>Purpose: retrieve financial impact after transactions"]
        T7["generate_financial_report()<br/>Purpose: produce end-of-run asset and performance summary"]
    end

    DB["🗄️ SQLite Database<br/>(inventory, quotes, transactions)"]

    Customer -->|"inquiry / quote / order"| Orch
    Orch -->|"inventory inquiry"| Inv
    Orch -->|"quote request"| Quote
    Orch -->|"sales order"| Sales

    Inv -->|"item stock lookup"| T1
    Inv -->|"inventory context"| T2
    Inv -->|"reorder ETA"| T3

    Quote -->|"historical pricing"| T4
    Quote -->|"availability context"| T2

    Sales -->|"record completed sale"| T5
    Sales -->|"post-sale cash check"| T6
    Sales -->|"availability validation"| T1

    T1 --> DB
    T2 --> DB
    T3 --> DB
    T4 --> DB
    T5 --> DB
    T6 --> DB
    T7 --> DB

    Inv -->|"stock status + reorder recommendation"| Orch
    Quote -->|"quote amount + rationale"| Orch
    Sales -->|"sale status or rejection reason"| Orch

    Orch -->|"final customer-facing response"| Response
    Orch -.->|"evaluation/reporting stage"| T7
